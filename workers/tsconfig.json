{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["*"]
    },
    "outDir": "./dist",
    "rootDir": ".."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "app", "components"]
}
