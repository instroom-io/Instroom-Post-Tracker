# ── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Production: https://app.instroom.co
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── EnsembleData ──────────────────────────────────────────────────────────────
# From: ensembledata.com → Account → API Token
# Used as ?token= query parameter on all EnsembleData API requests
ENSEMBLE_API_KEY=your_ensembledata_token_here
ENSEMBLE_API_URL=https://ensembledata.com/apis

# ── Google Drive ──────────────────────────────────────────────────────────────
# Base64-encoded Google service account JSON key file
# Generate: cat service-account.json | base64 | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Service account email — displayed to agencies in Settings → Storage so they know what to share their Drive folder with
# Value is the `client_email` field from the service account JSON key (not a secret — safe to expose publicly)
NEXT_PUBLIC_GOOGLE_SERVICE_ACCOUNT_EMAIL=   # e.g. instroom-uploader@your-project.iam.gserviceaccount.com

# Google OAuth (for per-user "Save to My Drive" feature)
GOOGLE_OAUTH_CLIENT_ID=         # Google Cloud Console → OAuth 2.0 Credentials → Web application
GOOGLE_OAUTH_CLIENT_SECRET=     # Google Cloud Console → OAuth 2.0 Credentials → Web application

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
# From: SendGrid dashboard → Settings → API Keys
# SENDGRID_FROM_EMAIL must be a verified sender in your SendGrid account
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=notifications@yourdomain.com
# Agency admin inbox — receives email when a new brand request is submitted
AGENCY_NOTIFICATION_EMAIL=admin@youragency.com

# ── Access Control ────────────────────────────────────────────────────────────
# Agency admin email — only this address can sign up without an invite.
# All other accounts must be created via an invite link (/invite/[token]).
ADMIN_EMAIL=admin@youragency.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=          # From Upstash console → Redis DB → REST URL
UPSTASH_REDIS_REST_TOKEN=        # From Upstash console → Redis DB → REST Token

# ── Lemon Squeezy Billing ─────────────────────────────────────────────────────
# Dashboard: app.lemonsqueezy.com
# API key: Settings → API → Generate key
LEMONSQUEEZY_API_KEY=                       # Server only — never expose to browser

# Store ID: visible in Settings or dashboard URL (e.g. /stores/12345)
LEMONSQUEEZY_STORE_ID=                      # Numeric store ID

# Webhook signing secret: Settings → Webhooks → your webhook → Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=                # Server only — used for HMAC-SHA256 verification

# Variant IDs: Products → [product] → Variants → edit each → note ID from URL
# All server-only — checkout URL is created server-side, variants never exposed to browser
LEMONSQUEEZY_SOLO_MONTHLY_VARIANT_ID=       # Post Tracker Solo $19/month variant
LEMONSQUEEZY_SOLO_ANNUAL_VARIANT_ID=        # Post Tracker Solo $180/year variant ($15/mo × 12)
LEMONSQUEEZY_TEAM_MONTHLY_VARIANT_ID=       # Post Tracker Team $39/month base variant
LEMONSQUEEZY_TEAM_ANNUAL_VARIANT_ID=        # Post Tracker Team $348/year base variant ($29/mo × 12)

# ── Billing Mock State (dev/testing only) ─────────────────────────────────────
# Override trial state in the UI without changing the DB.
# Values: 14 (normal), 7 (amber warning), 2 (red critical), 0 (expires today), -1 (grace), -5 (hard-expired)
# Unset or leave empty to use real DB values.
NEXT_PUBLIC_TRIAL_DAYS_REMAINING=       # e.g. 14
NEXT_PUBLIC_SUBSCRIPTION_ACTIVE=false   # true = skip trial UI, show Active state
